  m_Script: {fileID: 11500000, guid: cfb184dd38e35214b97e53b268a5b88a, type: 3}
  m_Name: Station 4
  m_EditorClassIdentifier: Assembly-CSharp::FantasyStationConfig
  stationID: S4
  question: You have implemented a TTS system in a mobile app for reading out news
    articles. However, users have reported that some words and names are mispronounced,
    disrupting their listening experience
  answers:
  - answerText: Adjust the speed and pitch of the TTS output.
    ingredientID: S4 1
  - answerText: Get the audio recorded by a professional voice-over artist.
    ingredientID: S4 2
  - answerText: Increase the volume of the TTS output.
    ingredientID: S4 3
  - answerText: Update the phonetic database to include correct pronunciations for
      commonly mispronounced words.
    ingredientID: S4 4
  correctIngredientIDs:
  - S4 4
